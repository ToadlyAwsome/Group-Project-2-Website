<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.okcu.tablefx.TableFXController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TableView fx:id="personTableView"
               prefHeight="250.0"
               prefWidth="500.0"
               maxWidth="550.0">

        <columns>
            <TableColumn fx:id="idColumn"
                         prefWidth="75.0"
                         text="Class ID"/>

            <TableColumn fx:id="firstNameColumn"
                         prefWidth="140.0"
                         text="Course Name"/>

            <TableColumn fx:id="lastNameColumn"
                         prefWidth="120.0"
                         text="Professor"/>

            <TableColumn fx:id="emailColumn"
                         prefWidth="100.0"
                         text="Room"/>

            <TableColumn fx:id="ageColumn"
                         prefWidth="90.0"
                         text="Students"/>
        </columns>

    </TableView>

    <HBox spacing="10">
        <Button text="Add Class" onAction="#onAddPerson"/>
        <Button text="Delete Class" onAction="#onDeletePerson"/>
        <Button text="Update Class" onAction="#onUpdatePerson"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Load From File" onAction="#onLoadFromFile"/>
        <Button text="Save To File" onAction="#onSaveToFile"/>
    </HBox>

</VBox>