<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.okcu.tablefx.TableFXController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TableView fx:id="personTableView" prefHeight="200.0" prefWidth="200.0" maxWidth="450.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
            <TableColumn fx:id="firstNameColumn" prefWidth="75.0" text="First Name" />
            <TableColumn fx:id="lastNameColumn" prefWidth="75.0" text="Last Name" />
            <TableColumn fx:id="emailColumn" prefWidth="150.0" text="Email" />
            <TableColumn fx:id="ageColumn" text="Age" />
        </columns>
    </TableView>

    <HBox>
        <Button text="Add Person" onAction="#onAddPerson" />
        <Button text="Delete Person" onAction="#onDeletePerson" />
        <Button text="Update Person" onAction="#onUpdatePerson" />
    </HBox>
    <HBox>
        <Button text="Load From File" onAction="#onLoadFromFile" />
        <Button text="Save to File" onAction="#onSaveToFile" />
    </HBox>
</VBox>
