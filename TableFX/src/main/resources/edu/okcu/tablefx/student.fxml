<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.okcu.tablefx.StudentController"
            prefHeight="400.0" prefWidth="600.0">

    <children>
        <VBox spacing="10.0" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0"
              AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
            <children>
                <Label text="Student Classes" />

                <TableView fx:id="classTable" prefHeight="250.0">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                        <TableColumn fx:id="codeColumn" text="Course Room" prefWidth="120.0" />
                        <TableColumn fx:id="nameColumn" text="Course Name" prefWidth="220.0" />
                        <TableColumn fx:id="profColumn" text="Professor" prefWidth="150.0" />
                    </columns>
                </TableView>

                <GridPane hgap="8" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="75" />
                    </columnConstraints>

                    <children>
                        <Label text="Course Room:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="codeField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Course Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Label text="Professor:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="profField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                    </children>
                </GridPane>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Add" onAction="#handleAddClass" />
                        <Button text="Update" onAction="#handleUpdateClass" />
                        <Button text="Delete" onAction="#handleDeleteClass" />
                        <Button text="Save" onAction="#handleSaveFile" />
                        <Button text="Load" onAction="#handleLoadFile" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
